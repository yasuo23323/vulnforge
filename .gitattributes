# Shell scripts — must stay LF on all platforms
*.sh     text eol=lf

# Python — LF for Linux compatibility
*.py     text eol=lf

# Docker
Dockerfile   text eol=lf
*.dockerfile text eol=lf

# Configs
*.yml    text eol=lf
*.yaml   text eol=lf
*.env    text eol=lf
.env.example text eol=lf

# Markdown, text
*.md     text eol=lf
*.txt    text eol=lf
*.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.png    binary
*.jpg    binary
*.zip    binary
*.tgz    binary
*.exe    binary
*.db     binary

# Node / frontend
*.tsx    text eol=lf
*.ts     text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.css    text eol=lf
*.html   text eol=lf