# VulnForge Configuration
# Copy this file to .env and fill in your values

# Database (options: sqlite | postgres)
DATABASE_TYPE=sqlite

# PostgreSQL (used when DATABASE_TYPE=postgres)
POSTGRES_DATABASE_URL=postgresql+asyncpg://vulnforge:vulnforge@localhost:5432/vulnforge

# SQLite (used when DATABASE_TYPE=sqlite)
DATABASE_URL=sqlite+aiosqlite:///./vulnforge.db

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# LLM API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Default LLM Model
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514

# Debug
DEBUG=true
